{
  "name": "map-sprite",
  "version": "0.1.0",
  "description": "Framework-independent TypeScript utilities for generating MapLibre and Mapbox sprite assets from SVG icons.",
  "type": "module",
  "main": "./dist/map-sprite.umd.cjs",
  "module": "./dist/map-sprite.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/map-sprite.js",
      "require": "./dist/map-sprite.umd.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 examples/react-basic",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "maplibre",
    "mapbox",
    "sprite",
    "svg",
    "canvas"
  ],
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1",
    "maxrects-packer": "^2.7.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
